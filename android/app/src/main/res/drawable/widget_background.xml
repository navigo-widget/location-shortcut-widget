<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted glass widget background — minimal translucency so the wallpaper
     reads through. Three layers: faint base fill, soft top→bottom highlight
     gradient, and a thin border for the glass edge. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#14FFFFFF" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#1AFFFFFF"
                android:endColor="#08FFFFFF"
                android:angle="135" />
            <corners android:radius="28dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="28dp" />
            <stroke
                android:width="0.5dp"
                android:color="#38FFFFFF" />
        </shape>
    </item>
</layer-list>
