<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted glass tile background — low translucency to match the minimal
     frost container. Base fill, faint top highlight, thin border. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#2EFFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item android:top="0dp" android:bottom="24dp">
        <shape android:shape="rectangle">
            <solid android:color="#14FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
            <corners android:radius="16dp" />
            <stroke
                android:width="0.5dp"
                android:color="#40FFFFFF" />
        </shape>
    </item>
</layer-list>
