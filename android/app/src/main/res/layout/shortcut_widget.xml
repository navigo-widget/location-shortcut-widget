<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <!-- Title -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="My Places"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#212121"
        android:paddingBottom="8dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp" />

    <!-- Shortcut grid (2 columns, up to 3 rows = 6 shortcuts max) -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:rowCount="3"
        android:useDefaultMargins="true">

        <!-- Slot 1 -->
        <LinearLayout
            android:id="@+id/slot_0"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_button_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_0"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- Slot 2 -->
        <LinearLayout
            android:id="@+id/slot_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_button_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- Slot 3 -->
        <LinearLayout
            android:id="@+id/slot_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_button_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- Slot 4 -->
        <LinearLayout
            android:id="@+id/slot_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_button_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- Slot 5 -->
        <LinearLayout
            android:id="@+id/slot_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_button_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="4dp" />
        </LinearLayout>

        <!-- Slot 6 -->
        <LinearLayout
            android:id="@+id/slot_5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:background="@drawable/widget_button_bg"
            android:visibility="gone">
            <ImageView
                android:id="@+id/icon_5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_mylocation" />
            <TextView
                android:id="@+id/label_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:paddingTop="4dp" />
        </LinearLayout>

    </GridLayout>
</LinearLayout>
