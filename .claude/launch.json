{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Flutter Debug (Android)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "--dart-define=PLACES_API_KEY=${PLACES_API_KEY}"],
      "port": 8080
    },
    {
      "name": "Flutter Web (Debug)",
      "runtimeExecutable": "flutter",
      "runtimeArgs": ["run", "-d", "chrome", "--web-port=3000", "--dart-define=PLACES_API_KEY=${PLACES_API_KEY}"],
      "port": 3000
    },
    {
      "name": "Static Preview",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8888"],
      "port": 8888
    }
  ]
}
